# Email Verification
# Use Firebase Email Verification + App Deep Linking (No Dynamic Links)
# Instead of Firebase Dynamic Links, configure your app to handle deep links
# and provide a verification URI that opens the app to the verification route.
# Examples:
# - App URI scheme: myapp://verify
# - Universal/App Link (HTTPS): https://example.com/verify
# Set one of the variables below depending on your deep-linking approach.
# Full app deep link URI that will be embedded in verification emails
EXPO_APP_DEEP_LINK_URI=aivehiclehealthmonitoringapp://verify
# Optional: If you use a web redirect URL that then forwards to the app,
# set the web URL (useful for platforms/browsers that don't open app schemes)
EXPO_EMAIL_VERIFICATION_WEB_URL=http://localhost:8081/verify

# Platform IDs
EXPO_IOS_BUNDLE_ID=com.kj.aivehiclehealthmonitoringapp
EXPO_ANDROID_PACKAGE_NAME=com.kj.aivehiclehealthmonitoringapp
EXPO_APPLE_TEAM_ID=

# App Settings
EXPO_ENV=development
EXPO_MAX_VERIFICATION_RESENDS=3
EXPO_RESEND_COOLDOWN_MINUTES=5

# Optional email settings
EXPO_EMAIL_FROM=noreply@yourcompany.com
EXPO_EMAIL_FROM_NAME=Your Vehicle Health App

# Deep linking paths
EXPO_DEEP_LINK_VERIFICATION_PATH=/verify
EXPO_DEEP_LINK_PASSWORD_RESET_PATH=/reset-password

