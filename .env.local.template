# Firebase Configuration - Email Verification
# Copy this content to `.env.local` in project root

# ============================================
# EMAIL VERIFICATION URL (REQUIRED)
# ============================================
# This URL is included in the verification email sent to users
# Firebase redirects the verification link to this URL

# Production: Deploy to Firebase Hosting first
EXPO_PUBLIC_EMAIL_VERIFICATION_WEB_URL=https://ai-based-smart-vehicle-health.web.app/verify-email

# Development/Testing options:
# Option 1: Local development server (if running locally)
# EXPO_PUBLIC_EMAIL_VERIFICATION_WEB_URL=http://localhost:3000/verify-email

# Option 2: Custom domain (if you have one)
# EXPO_PUBLIC_EMAIL_VERIFICATION_WEB_URL=https://yourapp.com/verify-email

# ============================================
# DEEP LINKING (Optional - for mobile apps)
# ============================================
# Use this if you want verification to open directly in the mobile app
# EXPO_PUBLIC_DEEP_LINK_VERIFICATION_URL=vehiclehealth://verify-email

# ============================================
# MOBILE APP IDENTIFIERS (Optional)
# ============================================
# Only needed if using deep linking above
# EXPO_IOS_BUNDLE_ID=com.yourcompany.vehicleapp
# EXPO_ANDROID_PACKAGE_NAME=com.yourcompany.vehicleapp

# ============================================
# FIREBASE CONFIGURATION
# ============================================
# These are already in firebaseConfig.tsx, but you can override here if needed:
# EXPO_FIREBASE_API_KEY=YOUR_API_KEY
# EXPO_FIREBASE_AUTH_DOMAIN=ai-based-smart-vehicle-health.firebaseapp.com
# EXPO_FIREBASE_PROJECT_ID=ai-based-smart-vehicle-health
# EXPO_FIREBASE_STORAGE_BUCKET=ai-based-smart-vehicle-health.firebasestorage.app
# EXPO_FIREBASE_MESSAGING_SENDER_ID=728879810111
# EXPO_FIREBASE_APP_ID=1:728879810111:web:eeff691ca1defdac66da8a

# ============================================
# NOTES
# ============================================
# 1. Only set EXPO_PUBLIC_EMAIL_VERIFICATION_WEB_URL - this is the critical one
# 2. Don't commit this to git if it contains secrets
# 3. Add to .gitignore: .env.local
# 4. Restart app after saving changes
# 5. Check console logs: [Email Verification] ✅ SUCCESS
