{
  "name": "ai-vehicle-health-monitoring-app",
  "main": "expo/AppEntry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "prebuild": "expo prebuild",
    "prebuild:android": "expo prebuild --platform android",
    "prebuild:ios": "expo prebuild --platform ios",
    "build": "expo export --platform web",
    "android": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:JAVA_HOME='C:\\Program Files\\Android\\Android Studio\\jbr'; $env:Path='C:\\Program Files\\Android\\Android Studio\\jbr\\bin;' + $env:Path; Remove-Item Env:_JAVA_OPTIONS -ErrorAction SilentlyContinue; Remove-Item Env:JAVA_OPTS -ErrorAction SilentlyContinue; Remove-Item Env:GRADLE_OPTS -ErrorAction SilentlyContinue; expo run:android --no-build-cache\"",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "firebase:doctor": "node scripts/firebase-doctor.js",
    "android:all": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:JAVA_HOME='C:\\Program Files\\Android\\Android Studio\\jbr'; $env:Path='C:\\Program Files\\Android\\Android Studio\\jbr\\bin;' + $env:Path; Remove-Item Env:_JAVA_OPTIONS -ErrorAction SilentlyContinue; Remove-Item Env:JAVA_OPTS -ErrorAction SilentlyContinue; Remove-Item Env:GRADLE_OPTS -ErrorAction SilentlyContinue; expo run:android --all-arch --no-build-cache\"",
    "postinstall": "node scripts/patch-expo-android-abi.js"
  },
  "dependencies": {
    "@dataconnect/generated": "file:src/dataconnect-generated",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-firebase/auth": "^23.8.8",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "axios": "^1.13.5",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-notifications": "^0.32.16",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
