{
  "expo": {
    "name": "AI-Vehicle-Health-Monitoring-App",
    "slug": "AI-Vehicle-Health-Monitoring-App",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aivehicle",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aivehicle.smarthealth",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.aivehicle.smarthealth",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "fontFamily": "system-ui"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "firebaseApiKey": "AIzaSyDowbCOXreWmH7FS_4mKgVWkMVJUiiCTXQ",
      "firebaseProjectId": "ai-based-smart-vehicle-h-b714b",
      "firebaseAuthDomain": "ai-based-smart-vehicle-h-b714b.firebaseapp.com",
      "firebaseStorageBucket": "ai-based-smart-vehicle-h-b714b.firebasestorage.app",
      "firebaseMessagingSenderId": "414445888340",
      "firebaseAppId": "1:414445888340:web:bdff515ff0415d4a6b9ec1",
      "apiUrl": "http://localhost:8081"
    }
  }
}
